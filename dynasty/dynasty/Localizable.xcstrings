    "Difficulty": {
      "extractionState": "manual",
      "localizations": {
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaikeustaso"
          }
        }
      }
    },
    "Difficulty affects AI roster construction, trade valuation, and free-agent competition. Play Clock limits live-game decision time — when it runs out, the QB or defense checks into a simple base call (never a penalty).": {
      "extractionState": "manual",
      "localizations": {
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaikeustaso vaikuttaa tekoälyn rosterinrakennukseen, vaihtokauppojen arvostukseen ja free agent -kilpailuun. Play clock rajaa päätösajan ottelussa — ajan loppuessa QB tai puolustus vaihtaa yksinkertaiseen peruspeliin (ei koskaan rangaistusta)."
          }
        }
      }
    },
    "Difficulty weighs roster talent, cap room, and draft capital.": {
      "extractionState": "manual",
      "localizations": {
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaikeus punnitsee rosterin lahjakkuuden, cap-tilan ja draft-pääoman."
          }
        }
      }
    },
